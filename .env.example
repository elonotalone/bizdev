# bizdev.oceanleo.com — 外贸/出海 AI 工作台. Thin client of the OceanLeo unified
# AI gateway.
#
# Auth + AI both go through the shared OceanLeo account (one login powers every
# OceanLeo site). Same oceanleo Supabase project + gateway as the other sites.

# OceanLeo shared account (isolated `oceanleo` Supabase project). The anon key
# is public by design; RLS protects data.
NEXT_PUBLIC_OCEANLEO_SUPABASE_URL=https://kvrtcumcmhyqhmawpzyc.supabase.co
NEXT_PUBLIC_OCEANLEO_ANON_KEY=

# Cross-subdomain SSO cookie parent domain. Leave default in prod.
NEXT_PUBLIC_OCEANLEO_COOKIE_DOMAIN=.oceanleo.com

# Unified AI gateway base. Defaults to prod; override for local gateway dev.
NEXT_PUBLIC_OCEANLEO_GATEWAY_URL=https://api.oceanleo.com
